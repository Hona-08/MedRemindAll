<?php
/**
 * @file
 * Tests for MedRemind module.
 *
 * TO RUN:
 *   Admin → Configuration → Development → Testing
 *   Check "MedRemind" group → Run tests
 */


/**
 * Test 1: Module installs correctly.
 */
class MedRemindInstallTestCase extends DrupalWebTestCase {

  public static function getInfo() {
    return array(
      'name' => 'MedRemind Installation',
      'description' => 'Test that MedRemind installs and creates database tables.',
      'group' => 'MedRemind',
    );
  }

  public function setUp() {
    parent::setUp(array('entity', 'medremind'));
  }

  public function testTablesExist() {
    $tables = array(
      'medremind_medications',
      'medremind_schedule',
      'medremind_log',
      'medremind_reminders',
      'medremind_streaks',
      'medremind_settings',
      'medremind_notifications',
      'medremind_prescriptions',
    );
    foreach ($tables as $table) {
      $this->assertTrue(db_table_exists($table),
        t('Table @table exists.', array('@table' => $table)));
    }
  }

  public function testDefaultVariables() {
    $this->assertEqual(variable_get('medremind_site_name', ''), 'MedRemind',
      'Default site name is set.');
    $this->assertEqual(variable_get('medremind_reminder_enabled', 0), 1,
      'Reminders enabled by default.');
    $this->assertEqual(variable_get('medremind_max_medications', 0), 20,
      'Default max medications is 20.');
  }

  public function testPermissionsExist() {
    $permissions = module_invoke('medremind', 'permission');
    $this->assertTrue(isset($permissions['use medremind']), 'Permission "use medremind" defined.');
    $this->assertTrue(isset($permissions['administer medremind']), 'Permission "administer medremind" defined.');
  }
}


/**
 * Test 2: Access control.
 */
class MedRemindAccessTestCase extends DrupalWebTestCase {

  public static function getInfo() {
    return array(
      'name' => 'MedRemind Access Control',
      'description' => 'Test page access with different user roles.',
      'group' => 'MedRemind',
    );
  }

  public function setUp() {
    parent::setUp(array('entity', 'medremind'));
  }

  public function testAnonymousAccessDenied() {
    $this->drupalGet('medremind');
    $this->assertResponse(403, 'Anonymous user gets 403 on dashboard.');
  }

  public function testAnonymousCannotAdd() {
    $this->drupalGet('medremind/add');
    $this->assertResponse(403, 'Anonymous user gets 403 on add form.');
  }

  public function testAuthorizedUserAccess() {
    $user = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($user);
    $this->drupalGet('medremind');
    $this->assertResponse(200, 'Authorized user can access dashboard.');
  }

  public function testUnauthorizedUserDenied() {
    $user = $this->drupalCreateUser(array());
    $this->drupalLogin($user);
    $this->drupalGet('medremind');
    $this->assertResponse(403, 'User without permission gets 403.');
  }

  public function testRegularUserCannotAccessAdmin() {
    $user = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($user);
    $this->drupalGet('admin/config/medremind');
    $this->assertResponse(403, 'Regular user cannot access admin settings.');
  }

  public function testAdminCanAccessSettings() {
    $admin = $this->drupalCreateUser(array('administer medremind'));
    $this->drupalLogin($admin);
    $this->drupalGet('admin/config/medremind');
    $this->assertResponse(200, 'Admin can access settings page.');
  }
}


/**
 * Test 3: Medication CRUD.
 */
class MedRemindMedicationCRUDTestCase extends DrupalWebTestCase {

  protected $testUser;

  public static function getInfo() {
    return array(
      'name' => 'MedRemind Medication CRUD',
      'description' => 'Test adding, editing, and deleting medications.',
      'group' => 'MedRemind',
    );
  }

  public function setUp() {
    parent::setUp(array('entity', 'medremind'));
    $this->testUser = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($this->testUser);
  }

  public function testAddFormLoads() {
    $this->drupalGet('medremind/add');
    $this->assertResponse(200, 'Add medication page loads.');
    $this->assertFieldByName('name', '', 'Name field exists.');
    $this->assertFieldByName('dosage', '', 'Dosage field exists.');
    $this->assertFieldByName('frequency', 'once_daily', 'Frequency field has default.');
  }

  public function testAddMedication() {
    $edit = array(
      'name' => 'Paracetamol',
      'dosage' => '500mg',
      'frequency' => 'twice_daily',
      'time_1' => '08:00',
      'time_2' => '20:00',
      'notes' => 'Take after meals',
    );

    $this->drupalPost('medremind/add', $edit, t('Add Medication'));
    $this->assertText('added', 'Success message shown.');
    $this->assertUrl('medremind', array(), 'Redirected to dashboard.');
    $this->assertText('Paracetamol', 'Medication name on dashboard.');
    $this->assertText('500mg', 'Dosage on dashboard.');

    $count = db_select('medremind_medications', 'm')
      ->condition('m.uid', $this->testUser->uid)
      ->condition('m.name', 'Paracetamol')
      ->countQuery()->execute()->fetchField();
    $this->assertEqual($count, 1, 'Medication saved to database.');
  }

  public function testValidationEmptyName() {
    $edit = array(
      'name' => '',
      'dosage' => '500mg',
      'time_1' => '08:00',
    );
    $this->drupalPost('medremind/add', $edit, t('Add Medication'));
    $this->assertText('required', 'Empty name shows error.');
  }

  public function testValidationShortName() {
    $edit = array(
      'name' => 'A',
      'dosage' => '500mg',
      'time_1' => '08:00',
    );
    $this->drupalPost('medremind/add', $edit, t('Add Medication'));
    $this->assertText('at least 2 characters', 'Short name shows error.');
  }

  public function testValidationInvalidTime() {
    $edit = array(
      'name' => 'Aspirin',
      'dosage' => '100mg',
      'time_1' => '25:00',
    );
    $this->drupalPost('medremind/add', $edit, t('Add Medication'));
    $this->assertText('HH:MM', 'Invalid time shows error.');
  }

  public function testEditMedication() {
    $med_id = db_insert('medremind_medications')->fields(array(
      'uid' => $this->testUser->uid, 'name' => 'Original Name', 'dosage' => '100mg',
      'frequency' => 'once_daily', 'times' => '["08:00"]', 'start_date' => REQUEST_TIME,
      'end_date' => 0, 'status' => 1, 'created' => REQUEST_TIME, 'updated' => REQUEST_TIME,
    ))->execute();

    $this->drupalGet('medremind/edit/' . $med_id);
    $this->assertResponse(200, 'Edit page loads.');
    $this->assertFieldByName('name', 'Original Name', 'Name pre-filled.');

    $edit = array('name' => 'Updated Name', 'dosage' => '200mg', 'time_1' => '09:00');
    $this->drupalPost('medremind/edit/' . $med_id, $edit, t('Update Medication'));
    $this->assertText('updated', 'Update success message.');

    $updated = db_query('SELECT name FROM {medremind_medications} WHERE med_id = :id',
      array(':id' => $med_id))->fetchField();
    $this->assertEqual($updated, 'Updated Name', 'Name updated in database.');
  }

  public function testDeleteMedication() {
    $med_id = db_insert('medremind_medications')->fields(array(
      'uid' => $this->testUser->uid, 'name' => 'Delete Me', 'dosage' => '50mg',
      'frequency' => 'once_daily', 'times' => '["08:00"]', 'start_date' => REQUEST_TIME,
      'end_date' => 0, 'status' => 1, 'created' => REQUEST_TIME, 'updated' => REQUEST_TIME,
    ))->execute();

    $this->drupalGet('medremind/delete/' . $med_id);
    $this->assertResponse(200, 'Delete confirmation loads.');
    $this->assertText('Are you sure', 'Confirmation shown.');

    $this->drupalPost('medremind/delete/' . $med_id, array(), t('Delete'));
    $this->assertText('deleted', 'Delete success message.');

    $exists = db_query('SELECT COUNT(*) FROM {medremind_medications} WHERE med_id = :id',
      array(':id' => $med_id))->fetchField();
    $this->assertEqual($exists, 0, 'Medication removed from database.');
  }

  public function testCannotEditOtherUserMed() {
    $med_id = db_insert('medremind_medications')->fields(array(
      'uid' => $this->testUser->uid, 'name' => 'Private Med', 'dosage' => '10mg',
      'frequency' => 'once_daily', 'times' => '["08:00"]', 'start_date' => REQUEST_TIME,
      'end_date' => 0, 'status' => 1, 'created' => REQUEST_TIME, 'updated' => REQUEST_TIME,
    ))->execute();

    $otherUser = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($otherUser);
    $this->drupalGet('medremind/edit/' . $med_id);
    $this->assertResponse(403, 'Other user cannot edit.');
  }
}


