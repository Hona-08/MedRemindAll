/**
 * Test 5: AJAX Take/Skip.
 */
class MedRemindAjaxTestCase extends DrupalWebTestCase {

  protected $testUser;
  protected $medId;

  public static function getInfo() {
    return array(
      'name' => 'MedRemind Take/Skip Actions',
      'description' => 'Test AJAX take and skip dose functionality.',
      'group' => 'MedRemind',
    );
  }

  public function setUp() {
    parent::setUp(array('entity', 'medremind'));
    $this->testUser = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($this->testUser);

    $this->medId = db_insert('medremind_medications')->fields(array(
      'uid' => $this->testUser->uid, 'name' => 'Test Med', 'dosage' => '50mg',
      'frequency' => 'once_daily', 'times' => '["08:00"]', 'start_date' => REQUEST_TIME,
      'end_date' => 0, 'status' => 1, 'created' => REQUEST_TIME, 'updated' => REQUEST_TIME,
    ))->execute();

    db_insert('medremind_streaks')->fields(array(
      'uid' => $this->testUser->uid, 'med_id' => $this->medId,
      'current_streak' => 0, 'best_streak' => 0, 'last_taken' => 0,
    ))->execute();
  }

  public function testTakeDose() {
    $this->drupalGet('medremind/take/' . $this->medId . '/ajax');
    $response = drupal_json_decode($this->drupalGetContent());
    $this->assertEqual($response['status'], 'ok', 'Take returns ok.');
    $this->assertEqual($response['action'], 'taken', 'Action is taken.');

    $log = db_select('medremind_log', 'l')->fields('l')
      ->condition('l.med_id', $this->medId)->condition('l.action', 'taken')
      ->execute()->fetchObject();
    $this->assertNotNull($log, 'Log entry created.');
  }

  public function testSkipDose() {
    $this->drupalGet('medremind/skip/' . $this->medId . '/ajax');
    $response = drupal_json_decode($this->drupalGetContent());
    $this->assertEqual($response['status'], 'ok', 'Skip returns ok.');
    $this->assertEqual($response['action'], 'skipped', 'Action is skipped.');
  }

  public function testStreakUpdates() {
    $this->drupalGet('medremind/take/' . $this->medId . '/ajax');
    $streak = db_select('medremind_streaks', 's')
      ->fields('s', array('current_streak'))
      ->condition('s.med_id', $this->medId)
      ->execute()->fetchField();
    $this->assertEqual($streak, 1, 'Streak set to 1 after take.');
  }

  public function testSkipResetsStreak() {
    db_update('medremind_streaks')->fields(array('current_streak' => 5))
      ->condition('med_id', $this->medId)->execute();

    $this->drupalGet('medremind/skip/' . $this->medId . '/ajax');
    $streak = db_select('medremind_streaks', 's')
      ->fields('s', array('current_streak'))
      ->condition('s.med_id', $this->medId)
      ->execute()->fetchField();
    $this->assertEqual($streak, 0, 'Streak reset to 0 after skip.');
  }

  public function testCannotTakeOtherUserMed() {
    $otherUser = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($otherUser);
    $this->drupalGet('medremind/take/' . $this->medId . '/ajax');
    $this->assertResponse(403, 'Cannot take another user dose.');
  }
}


/**
 * Test 6: Admin settings.
 */
class MedRemindAdminTestCase extends DrupalWebTestCase {

  public static function getInfo() {
    return array(
      'name' => 'MedRemind Admin Settings',
      'description' => 'Test admin configuration page.',
      'group' => 'MedRemind',
    );
  }

  public function setUp() {
    parent::setUp(array('entity', 'medremind'));
  }

  public function testSaveSettings() {
    $admin = $this->drupalCreateUser(array('administer medremind'));
    $this->drupalLogin($admin);

    $edit = array(
      'medremind_site_name' => 'My Pharmacy App',
      'medremind_max_medications' => 50,
    );
    $this->drupalPost('admin/config/medremind', $edit, t('Save configuration'));
    $this->assertText('saved', 'Settings saved message.');
    $this->assertEqual(variable_get('medremind_site_name', ''), 'My Pharmacy App', 'Site name saved.');
  }

  public function testStatisticsDisplay() {
    $admin = $this->drupalCreateUser(array('administer medremind'));
    $this->drupalLogin($admin);
    $this->drupalGet('admin/config/medremind');
    $this->assertText('Users', 'Statistics shows Users.');
    $this->assertText('Medications', 'Statistics shows Medications.');
  }
}


/**
 * Test 7: Prescription Entity.
 */
class MedRemindPrescriptionTestCase extends DrupalWebTestCase {

  protected $testUser;

  public static function getInfo() {
    return array(
      'name' => 'MedRemind Prescriptions',
      'description' => 'Test Prescription entity CRUD.',
      'group' => 'MedRemind',
    );
  }

  public function setUp() {
    parent::setUp(array('entity', 'medremind'));
    $this->testUser = $this->drupalCreateUser(array('use medremind'));
    $this->drupalLogin($this->testUser);
  }

  public function testPrescriptionsPageLoads() {
    $this->drupalGet('medremind/prescriptions');
    $this->assertResponse(200, 'Prescriptions page loads.');
    $this->assertText('No prescriptions yet', 'Empty state shown.');
  }

  public function testCreatePrescriptionEntity() {
    // Create via Entity API directly
    $values = array(
      'uid' => $this->testUser->uid,
      'prescription_number' => 'RX-12345',
      'doctor_name' => 'Dr. Smith',
      'pharmacy_name' => 'City Pharmacy',
      'prescribed_date' => REQUEST_TIME,
      'expiry_date' => REQUEST_TIME + (365 * 86400),
      'refills_total' => 5,
      'refills_used' => 1,
      'notes' => 'Test prescription',
      'status' => 1,
    );

    $prescription = entity_create('medremind_prescription', $values);
    entity_save('medremind_prescription', $prescription);

    $this->assertNotNull($prescription->prescription_id, 'Prescription created with ID.');

    // Load it back
    $loaded = entity_load_single('medremind_prescription', $prescription->prescription_id);
    $this->assertEqual($loaded->prescription_number, 'RX-12345', 'Prescription number matches.');
    $this->assertEqual($loaded->doctor_name, 'Dr. Smith', 'Doctor name matches.');
    $this->assertEqual($loaded->refills_total, 5, 'Refills total matches.');
  }

  public function testEntityDelete() {
    $values = array(
      'uid' => $this->testUser->uid,
      'prescription_number' => 'RX-DELETE-ME',
      'doctor_name' => 'Dr. Test',
      'status' => 1,
    );
    $rx = entity_create('medremind_prescription', $values);
    entity_save('medremind_prescription', $rx);
    $id = $rx->prescription_id;

    entity_delete('medremind_prescription', $id);

    $exists = db_query('SELECT COUNT(*) FROM {medremind_prescriptions} WHERE prescription_id = :id',
      array(':id' => $id))->fetchField();
    $this->assertEqual($exists, 0, 'Prescription deleted from database.');
  }

  public function testPrescriptionTableExists() {
    $this->assertTrue(db_table_exists('medremind_prescriptions'), 'Prescriptions table exists.');
  }
}
