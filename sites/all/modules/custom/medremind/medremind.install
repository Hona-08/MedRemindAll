        'doctor_name' => array('type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''),
        'pharmacy_name' => array('type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''),
        'prescribed_date' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'expiry_date' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'refills_total' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'refills_used' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
        'notes' => array('type' => 'text', 'not null' => FALSE),
        'status' => array('type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 1),
        'created' => array('type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0),
