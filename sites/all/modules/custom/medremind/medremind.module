<?php
/**
 * @file
 * MedRemind — Medication Reminder SaaS for Drupal 7.
 */

define('MEDREMIND_STATUS_ACTIVE', 1);
define('MEDREMIND_STATUS_PAUSED', 0);
define('MEDREMIND_ACTION_TAKEN', 'taken');
define('MEDREMIND_ACTION_MISSED', 'missed');
define('MEDREMIND_ACTION_SKIPPED', 'skipped');

// Email: FALSE = block emails on localhost, TRUE = send real emails
if (!defined('MEDREMIND_SEND_EMAILS')) {
  define('MEDREMIND_SEND_EMAILS', FALSE);
}
function medremind_init() {
  global $user;

  // Grant permission on every page load if not set
  if ($user->uid > 0) {
    $role = user_role_load_by_name('authenticated user');
    if ($role) {
      $has = db_select('role_permission', 'rp')
        ->condition('rid', $role->rid)
        ->condition('permission', 'use medremind')
        ->countQuery()->execute()->fetchField();
      if (!$has) {
        user_role_grant_permissions($role->rid, array('use medremind'));
        drupal_static_reset('user_access');
        drupal_static_reset('user_role_permissions');
      }
    }
  }

  // Redirect anonymous users to login
  if ($user->uid == 0) {
    $path = current_path();
    $protected = array(
      'medremind', 'medremind/add', 'medremind/history', 'medremind/settings',
      'medremind/reports', 'medremind/notifications', 'medremind/export',
      'medremind/prescriptions', 'medremind/profile',
    );
    if (in_array($path, $protected)) {
      drupal_goto('medremind/login', array('query' => array('destination' => $path)));
    }
  }
}
