/**
 * Implements hook_permission().
 */
function medremind_permission() {
  return array(
    'administer medremind' => array('title' => t('Administer MedRemind')),
    'use medremind' => array('title' => t('Use MedRemind')),
  );
}


/**
 * Implements hook_theme().
 */
function medremind_theme() {
  $path = drupal_get_path('module', 'medremind') . '/templates';
  return array(
    'medremind_dashboard' => array(
      'template' => 'medremind-dashboard', 'path' => $path,
      'variables' => array('medications' => array(), 'stats' => array(), 'user_name' => ''),
    ),
    'medremind_med_card' => array(
      'template' => 'medremind-med-card', 'path' => $path,
      'variables' => array('medication' => NULL, 'next_dose' => '', 'streak' => 0),
    ),
    'medremind_history' => array(
      'template' => 'medremind-history', 'path' => $path,
      'variables' => array('logs' => array(), 'month' => '', 'adherence' => 0),
    ),
  );
}


/**
 * Implements hook_help().
 */
function medremind_help($path, $arg) {
  if ($path == 'admin/help#medremind') {
    return '<p>' . t('MedRemind helps users track medications and receive reminders.') . '</p>';
  }
}


/**
 * Implements hook_cron().
 */
function medremind_cron() {
  $loaded = module_load_include('inc', 'medremind', 'includes/medremind.cron');
  if ($loaded) {
    _medremind_process_reminders();
  }
}


/**
 * Implements hook_mail().
 */
function medremind_mail($key, &$message, $params) {
  $site = variable_get('medremind_site_name', 'MedRemind');

  if ($key == 'dose_reminder') {
    $message['subject'] = t('[@site] Time to take @med', array(
      '@site' => $site, '@med' => $params['med_name'],
    ));
    $message['body'][] = t("Hello,\n\nTime to take: @med (@dosage)\n\n— @site", array(
      '@med' => $params['med_name'],
      '@dosage' => $params['med_dosage'],
      '@site' => $site,
    ));
  }

  if ($key == 'daily_summary') {
    $message['subject'] = t('[@site] Daily Summary', array('@site' => $site));
    $message['body'][] = t("Today: Taken @t, Missed @m, Skipped @s\n\n— @site", array(
      '@t' => $params['taken'],
      '@m' => $params['missed'],
      '@s' => $params['skipped'],
      '@site' => $site,
    ));
  }
}
function medremind_mail_alter(&$message) {
  if (!defined('MEDREMIND_SEND_EMAILS') || !MEDREMIND_SEND_EMAILS) {
    // Block all medremind emails AND Drupal user emails on localhost
    if (strpos($message['id'], 'medremind') === 0 || strpos($message['id'], 'user_') === 0) {
      $message['send'] = FALSE;
    }
  }
}


/**
 * Implements hook_block_info().
 */
function medremind_block_info() {
  return array(
    'next_dose' => array('info' => t('MedRemind: Next Dose'), 'cache' => DRUPAL_NO_CACHE),
    'quick_stats' => array('info' => t('MedRemind: Quick Stats'), 'cache' => DRUPAL_NO_CACHE),
    'medremind_notifications' => array('info' => t('MedRemind: Notifications'), 'cache' => DRUPAL_NO_CACHE),
  );
}

/**
 * Implements hook_block_view().
 */
function medremind_block_view($delta = '') {
  module_load_include('inc', 'medremind', 'includes/medremind.blocks');
  if ($delta == 'next_dose') return _medremind_block_next_dose();
  if ($delta == 'quick_stats') return _medremind_block_quick_stats();
  if ($delta == 'medremind_notifications') {
    if (user_access('use medremind')) {
      return array('subject' => '', 'content' => _medremind_block_notifications());
    }
  }
}


/**
 * Access callback: does current user own this medication?
 */
function medremind_medication_access($med_id) {
  global $user;
  if (!user_access('use medremind')) return FALSE;
  if (user_access('administer medremind')) return TRUE;
  if (!db_table_exists('medremind_medications')) return FALSE;
  $owner = db_query('SELECT uid FROM {medremind_medications} WHERE med_id = :mid',
    array(':mid' => $med_id))->fetchField();
  return ($owner == $user->uid);
}
/**
 * Implements hook_entity_info().
 *
 * This tells Drupal about our custom Prescription entity.
 * Entity API module reads this and provides:
 *   - entity_load(), entity_save(), entity_delete()
 *   - Admin UI pages
 *   - Views integration
 *   - Fieldable support (attach fields via UI)
 */
function medremind_entity_info() {
  $info = array();

  $info['medremind_prescription'] = array(
    // Basic info
    'label' => t('Prescription'),
    'plural label' => t('Prescriptions'),
    'description' => t('Prescription records linked to medications.'),

    // Entity class and controller
    'entity class' => 'MedRemindPrescription',
    'controller class' => 'MedRemindPrescriptionController',

    // Database table
    'base table' => 'medremind_prescriptions',

    // Fieldable — allows attaching fields via UI
    'fieldable' => TRUE,

    // Keys — tells Drupal which columns are special
    'entity keys' => array(
      'id' => 'prescription_id',
      'label' => 'prescription_number',
    ),

    // Bundle — we only have one type
    'bundles' => array(
      'medremind_prescription' => array(
        'label' => t('Prescription'),
        'admin' => array(
          'path' => 'admin/structure/medremind-prescriptions',
          'access arguments' => array('administer medremind'),
        ),
      ),
    ),

    // Admin UI — Entity API generates admin pages
    'admin ui' => array(
      'path' => 'medremind/prescription',
      'controller class' => 'MedRemindPrescriptionUIController',
      'file' => 'includes/medremind.prescription.pages.inc',
    ),

    // Access callback
    'access callback' => 'medremind_prescription_access',

    // Module
    'module' => 'medremind',
  );

  return $info;
}


/**
 * Access callback for prescription entity.
 */
function medremind_prescription_access($op, $entity = NULL, $account = NULL) {
  if (user_access('administer medremind', $account)) {
    return TRUE;
  }
  if (user_access('use medremind', $account)) {
    if ($op == 'create') return TRUE;
    if ($entity && isset($entity->uid)) {
      global $user;
      $check_account = $account ? $account : $user;
      return ($entity->uid == $check_account->uid);
    }
    return TRUE;
  }
  return FALSE;
}